{
	"name": "atomic-calendar-revive",
	"version": "10.2.1",
	"description": "Calendar Card for Home Assistant",
	"main": "atomic-calendar-revive.js",
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src/*.ts",
		"lintindex": "eslint src/index.ts",
		"lintindexfix": "eslint src/index.ts --fix",
		"lintfixall": "eslint src/*.ts --fix",
		"linteditor": "eslint src/index-editor.ts",
		"babel": "babel dist/index.js --out-file dist/atomic-calendar-revive.js",
		"rollup": "rollup -c",
		"start": "rollup -c --watch --bundleConfigAsCjs",
		"build": "rollup -c --bundleConfigAsCjs",
		"watch": "rollup -c rollup-dev.config.mjs  --bundleConfigAsCjs",
		"commit": "cz"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/totaldebug/atomic-calendar-revive.git"
	},
	"author": "Steven Marks",
	"license": "ISC",
	"devDependencies": {
		"@babel/cli": "^7.28.6",
		"@babel/core": "^7.29.0",
		"@babel/plugin-proposal-class-properties": "^7.18.6",
		"@babel/plugin-proposal-decorators": "^7.29.0",
		"@babel/plugin-transform-template-literals": "^7.27.1",
		"@babel/preset-env": "^7.29.2",
		"@babel/preset-typescript": "^7.28.5",
		"@eslint/js": "^10.0.1",
		"@rollup/plugin-babel": "^7.0.0",
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-eslint": "^9.2.0",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"babel-preset-minify": "^0.5.2",
		"commitizen": "^4.3.1",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-prettier": "^5.5.5",
		"prettier": "^3.8.3",
		"rollup": "^4.60.2",
		"rollup-plugin-serve": "^3.0.0",
		"semantic-release": "^25.0.3",
		"typescript-eslint": "^8.59.0",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@formatjs/icu-messageformat-parser": "3.5.5",
		"@lit-labs/scoped-registry-mixin": "1.0.4",
		"@lit/reactive-element": "2.0.1",
		"@mdi/js": "7.4.47",
		"@webcomponents/webcomponentsjs": "2.8.0",
		"dayjs": "1.11.20",
		"home-assistant-js-websocket": "9.6.0",
		"lit": "^3.3.2",
		"memoize-one": "6.0.0",
		"npm": "11.13.0",
		"tslib": "^2.8.1",
		"typescript": "6.0.3"
	},
	"resolutions": {
		"lit": "^3.0.2",
		"@lit/reactive-element": "2.0.1"
	},
	"bugs": {
		"url": "https://github.com/totaldebug/atomic-calendar-revive/issues"
	},
	"homepage": "https://github.com/totaldebug/atomic-calendar-revive#readme",
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"release": {
		"plugins": [
			[
				"@semantic-release/commit-analyzer",
				{
					"preset": "conventionalcommits"
				}
			],
			[
				"@semantic-release/release-notes-generator",
				{
					"preset": "conventionalcommits"
				}
			],
			[
				"@semantic-release/npm",
				{
					"npmPublish": false
				}
			],
			[
				"@semantic-release/exec",
				{
					"prepareCmd": "pnpm run build"
				}
			],
			[
				"@semantic-release/git",
				{
					"assets": [
						"package.json"
					],
					"message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
				}
			],
			[
				"@semantic-release/github",
				{
					"assets": [
						{
							"path": "dist/atomic-calendar-revive.js"
						}
					]
				}
			],
			"@semantic-release/changelog"
		]
	}
}
